# Neon Postgres connection string (use a pooled URL for serverless)
DATABASE_URL=postgres://user:pass@ep-xxx-pooler.region.aws.neon.tech/opensheets?sslmode=require

# PartyKit host. Local dev: localhost:1999. Prod: opensheets.<your-handle>.partykit.dev
NEXT_PUBLIC_PARTY_HOST=localhost:1999

# Shared secret used by /api/cron/expire to authorize PartyKit doc deletion.
# Set the same value as ADMIN_TOKEN in PartyKit secrets.
ADMIN_TOKEN=replace-me

# Vercel Cron sets this header automatically when CRON_SECRET is defined.
CRON_SECRET=replace-me

# Optional overrides
DEFAULT_TTL_DAYS=14
MAX_TTL_DAYS=30
RATE_LIMIT_CREATE_PER_DAY=10
